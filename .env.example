# ── Compartilhadas (ws-server + web) ────────────────────────────
NODE_ENV=development
APP_BASE_URL=https://cursos.s-iron.tech

# Clerk (obter em dashboard.clerk.com)
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_FRONTEND_API_URL=SEU_FRONTEND_API_URL_DO_CLERK
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Roles raiz (emails separados por vírgula)
PLATFORM_ROOT_EMAILS=seu-email@dominio.com

# ── ws-server ────────────────────────────────────────────────────
SESSION_SECRET=troque-por-uma-string-longa-e-aleatoria-minimo-32-chars
ADMIN_PASSWORD=troque-por-senha-forte
PORT=3000

# ── web (Next.js) ────────────────────────────────────────────────
NEXT_PUBLIC_WS_URL=wss://cursos.s-iron.tech/ws
# Em dev local:
# NEXT_PUBLIC_WS_URL=ws://localhost:3001
